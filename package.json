    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.51.0",
    "eslint-config-next": "^14.0.0",
    "tailwindcss": "^3.3.0",
